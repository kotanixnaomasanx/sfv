# ローカルで試すとき用のサンプル。コピーして .env として使い、値を埋めてください。
# GitHub ではこれらを Secrets に登録します（.env はコミットしない）。

export NOTION_TOKEN="ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
export NEWS_DB_ID="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
export PAGES_DB_ID="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
export SCHEDULE_DB_ID="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# 使い方:  source .env && python3 build.py
